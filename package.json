{
    "name": "ok11-api",
    "version": "1.0.0",
    "description": "OK11 API Server - Production-ready Node.js API with Firebase Auth, FCM, and CRUD operations",
    "main": "dist/server.js",
    "type": "module",
    "packageManager": "pnpm@9.15.0",
    "imports": {
        "#shared/*": "./dist/shared/*",
        "shared/*": "./dist/shared/*",
        "modules/*": "./dist/modules/*"
    },
    "scripts": {
        "dev": "nodemon",
        "build": "tsc && tsc-alias",
        "start": "node dist/server.js",
        "start:prod": "NODE_ENV=production node dist/server.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "api",
        "express",
        "typescript",
        "firebase",
        "mongodb",
        "mongoose"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.936.0",
        "@aws-sdk/s3-request-presigner": "^3.936.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cors": "2.8.5",
        "dotenv": "17.2.3",
        "express": "5.1.0",
        "express-rate-limit": "8.2.1",
        "firebase-admin": "13.6.0",
        "helmet": "8.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "8.19.4",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "pino": "10.1.0",
        "pino-http": "11.0.0",
        "pino-pretty": "13.1.2",
        "zod": "4.1.12"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bcryptjs": "^3.0.0",
        "@types/compression": "^1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.5",
        "@types/jest": "30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "24.10.1",
        "@types/node-cron": "^3.0.11",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "8.46.4",
        "@typescript-eslint/parser": "8.46.4",
        "eslint": "9.39.1",
        "jest": "30.2.0",
        "mongodb-memory-server": "^10.3.0",
        "nodemon": "3.1.11",
        "prettier": "^3.6.2",
        "supertest": "^7.1.4",
        "ts-jest": "29.4.5",
        "ts-node": "10.9.2",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.20.6",
        "typescript": "5.9.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    }
}